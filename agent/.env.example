# =============================================================================
# CareerSIM Agent Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI API Configuration (REQUIRED)
# -----------------------------------------------------------------------------

# Your OpenAI API key (required for AI responses)
OPENAI_API_KEY=your-openai-api-key

# Base URL for OpenAI-compatible API
# Use https://api.openai.com/v1 for OpenAI direct
# Use https://openrouter.ai/api/v1 for OpenRouter
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Model to use for conversation generation
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# OpenRouter: openai/gpt-4o, anthropic/claude-3.5-sonnet, etc.
OPENAI_MODEL=openai/gpt-5.4

# Provider name (openai, anthropic, google, etc.)
OPENAI_PROVIDER=openai

# Maximum tokens in AI response
OPENAI_MAX_TOKENS=250000

# Temperature for response generation (0.0 = deterministic, 1.0 = creative)
OPENAI_TEMPERATURE=0.7

# Top-p (nucleus sampling) - alternative to temperature
OPENAI_TOP_P=1.0

# Frequency penalty (0.0 - 2.0) - reduces repetition of token sequences
OPENAI_FREQUENCY_PENALTY=0

# Presence penalty (0.0 - 2.0) - encourages new topics
OPENAI_PRESENCE_PENALTY=0

# -----------------------------------------------------------------------------
# Evaluation Model Configuration (Optional)
# Used for sentiment/emotion analysis and goal evaluation.
# Falls back to the main model above if not set.
# A smaller/cheaper model (e.g. flash) works well here.
# -----------------------------------------------------------------------------

# Model for evaluation tasks (defaults to main model if not set)
OPENAI_EVAL_MODEL=google/gemini-3.1-flash-lite

# Provider for evaluation model
OPENAI_EVAL_PROVIDER=google

OPENAI_EVAL_MAX_TOKENS=250000

# Lower temperature for more consistent evaluations
OPENAI_EVAL_TEMPERATURE=0.3
OPENAI_EVAL_TOP_P=1.0

# Penalties for evaluation model
OPENAI_EVAL_FREQUENCY_PENALTY=0.3
OPENAI_EVAL_PRESENCE_PENALTY=0.3

# -----------------------------------------------------------------------------
# RAG (Retrieval-Augmented Generation) Configuration
# -----------------------------------------------------------------------------

# Enable/disable RAG context retrieval
RAG_ENABLED=true

# OpenAI embedding model for document vectorization
RAG_EMBEDDING_MODEL=openai/text-embedding-3-large

# Text splitting parameters
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100

# Number of relevant chunks to retrieve per query
RAG_TOP_K=4

# Directory for ChromaDB persistent storage (relative to agent/)
RAG_CHROMA_PERSIST_DIR=.chroma_db

# -----------------------------------------------------------------------------
# Gradio UI Configuration
# -----------------------------------------------------------------------------

# Port for the Gradio web interface
GRADIO_SERVER_PORT=7860

# Set to true to create a public share link (useful for remote access)
GRADIO_SHARE=false

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# Internal API authentication
# -----------------------------------------------------------------------------
# Shared secret that the Fastify API must send as `X-Internal-Key` on
# every call into this agent. Must match `AGENT_INTERNAL_KEY` in
# `api/.env`. The value below is a development placeholder shared
# with `api/.env.example` so `docker compose up` wires auth end-to-end
# out of the box; replace both sides with a real secret (e.g.
# `openssl rand -hex 32`) before any shared / prod deploy.
#
# Leave empty for Gradio / pytest / running the agent standalone:
# the service starts, logs a one-line warning, and accepts
# unauthenticated calls.
AGENT_INTERNAL_KEY=dev-internal-key-change-me-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# Voice mode
# -----------------------------------------------------------------------------
# Browser-native voice support via a self-hosted LiveKit SFU plus a chained
# STT -> existing LangGraph turn -> TTS pipeline. Default providers are
# self-hosted (faster-whisper + Piper) so no third-party keys are required
# out of the box. Cloud providers (OpenAI Whisper/TTS, Deepgram, ElevenLabs)
# are opt-in via the *_PROVIDER env vars and their own keys.
#
# Master kill switch. When `false` the agent-voice worker logs a single
# info line and exits cleanly at startup; the FastAPI app and existing
# chat path are unaffected.
VOICE_ENABLED=true

# Per-user daily voice quota in minutes. Enforced server-side in `api/`,
# but mirrored here so the agent worker can self-throttle when running
# without the API in front (smoke tests, dev console).
VOICE_DAILY_MINUTES_PER_USER=20

# -- LiveKit (self-hosted SFU; brought up by docker-compose by default) --
# Use ws:// for plain dev, wss:// for any TLS-fronted deploy. The
# in-compose hostname is `livekit`; outside compose, swap for
# `localhost` (port 7880).
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-min-32-chars-change-me-openssl-rand-hex-32

# -- STT provider selection --
# whisper_local | whisper_openai | deepgram
VOICE_STT_PROVIDER=whisper_local

# faster-whisper (default STT) tuning. Models are prefetched into the
# Docker image during build; first-run downloads only happen when the
# selected model differs from the prefetched one.
VOICE_WHISPER_MODEL=base.en
VOICE_WHISPER_DEVICE=cpu
VOICE_WHISPER_COMPUTE_TYPE=int8

# -- TTS provider selection --
# piper_local | openai_tts | elevenlabs
VOICE_TTS_PROVIDER=piper_local

# Piper (default TTS) tuning. Voice models live in a named Docker volume
# so they survive `docker compose down`; the default voice is prefetched
# during image build.
VOICE_PIPER_MODEL_DIR=/app/.piper_models
VOICE_PIPER_DEFAULT_VOICE=en_US-libritts_r-medium

# -- Cloud provider keys (leave empty unless the corresponding provider is
# selected). OpenAI providers reuse `OPENAI_API_KEY` / `OPENAI_BASE_URL`
# from the chat configuration above.
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
