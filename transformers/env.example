# Environment Configuration Example for Transformer Models Microservice
# Copy this file to .env and update the values

# Authentication Token (minimum 32 characters required)
# Generate a secure random token for production
AUTH_TOKEN=your-super-secure-auth-token-min-32-chars-long-change-this-in-production

# Authentication Settings
# Set to 'false' to disable authentication (development only)
AUTH_REQUIRED=true

# Model Cache Configuration
# Paths for local development (Docker will override these)
TRANSFORMERS_CACHE=./models_cache
HF_HOME=./models_cache

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Logging Configuration
LOG_LEVEL=INFO

# Docker-specific overrides (set by docker-compose.yml):
# TRANSFORMERS_CACHE=/app/models_cache (in container)
# HF_HOME=/app/models_cache (in container)

# Example secure tokens (use these as reference):
# AUTH_TOKEN=sk-abc123def456ghi789jkl012mno345pqr678stu901vwx234yz
# AUTH_TOKEN=bearer_token_2024_secure_min_32_characters_long_example
# AUTH_TOKEN=api_key_production_very_secure_random_string_here