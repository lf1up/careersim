NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_NAME=careersim.local
NEXT_PUBLIC_SITE_URL=https://careersim.local
NEXT_PUBLIC_SITE_DESCRIPTION=Practice career conversations with AI simulations for interviews, workplace scenarios, feedback, and professional growth.
NEXT_PUBLIC_CONTACT_EMAIL=hello@careersim.local
LANDING_ORIGIN=

# Voice mode — browser-native WebRTC call surface.
# `NEXT_PUBLIC_VOICE_ENABLED=true` makes the web app render the Call
# button on session pages; flip to `false` to hide voice UI without
# touching the backend. Should match `VOICE_ENABLED` on api/agent.
# `NEXT_PUBLIC_LIVEKIT_URL` is the self-hosted LiveKit SFU's wss/ws
# endpoint as visible from the browser (NOT the in-compose hostname).
NEXT_PUBLIC_VOICE_ENABLED=true
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
