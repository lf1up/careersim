# FULL base URL of the api service, version path included. Nothing is
# appended in code (src/lib/api.ts, src/lib/public-api.ts, AltchaWidget),
# so this single var controls versioning — e.g. on Vercel set
# `https://api.careersim.ai/v1` for a versioned API or
# `https://api.careersim.ai` for one running without API_VERSION_PREFIX.
# Local default is /v1 because api/.env runs with API_VERSION_PREFIX=v1.
# No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_SITE_NAME=careersim.local
NEXT_PUBLIC_SITE_URL=https://careersim.local
NEXT_PUBLIC_SITE_DESCRIPTION=Practice career conversations with AI simulations for interviews, workplace scenarios, feedback, and professional growth.
NEXT_PUBLIC_CONTACT_EMAIL=hello@careersim.local
LANDING_ORIGIN=

# Blog surface (opt-in, off by default). Omit this var entirely, or set
# `false`/`0`, to keep the blog off. Requires NEXT_PUBLIC_BLOG_ENABLED=true
# (or `1`) and both GHOST_API_URL + GHOST_CONTENT_API_KEY to enable.
# Otherwise /blog routes 404 and blog URLs are omitted from sitemap /
# robots / llms.txt.
NEXT_PUBLIC_BLOG_ENABLED=false

# Headless Ghost CMS (Content API). Both URL and key are required for the
# blog to enable. Compose overrides GHOST_API_URL to http://ghost:2368;
# when running `pnpm dev` on the host use localhost.
GHOST_API_URL=http://localhost:2368
# Optional browser-facing Ghost origin for next/image remotePatterns when
# it differs from GHOST_API_URL (e.g. https://ghost.careersim.ai in prod).
GHOST_PUBLIC_URL=
# Content API key from Ghost Admin → Settings → Integrations → Add custom
# integration. Read-only; safe as a server-side env var (not NEXT_PUBLIC_).
GHOST_CONTENT_API_KEY=
# Shared secret for POST /api/revalidate?secret=… (Ghost publish webhook).
GHOST_WEBHOOK_SECRET=

# Voice mode — browser-native WebRTC call surface.
# `NEXT_PUBLIC_VOICE_ENABLED=true` makes the web app render the Call
# button on session pages; flip to `false` to hide voice UI without
# touching the backend. Should match `VOICE_ENABLED` on api/agent.
# `NEXT_PUBLIC_LIVEKIT_URL` is the self-hosted LiveKit SFU's wss/ws
# endpoint as visible from the browser (NOT the in-compose hostname).
NEXT_PUBLIC_VOICE_ENABLED=true
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
