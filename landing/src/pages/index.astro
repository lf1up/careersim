---
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';

const siteName = import.meta.env.LANDING_SITE_NAME?.trim() || 'careersim.local';
const siteUrl = import.meta.env.LANDING_SITE_URL?.trim() || 'https://careersim.local';
const githubUrl = import.meta.env.LANDING_GITHUB_URL ?? 'https://github.com/lf1up/careersim';
const appUrl = import.meta.env.LANDING_APP_URL ?? 'https://careersim.local/register';
const simulationsUrl = import.meta.env.LANDING_SIMULATIONS_URL ?? 'https://careersim.local/simulations';
const contactEmail = import.meta.env.LANDING_CONTACT_EMAIL ?? 'hello@careersim.local';

const previewSessions = [
  {
    id: 'negotiation',
    tabLabel: 'salary-negotiation',
    sessionTitle: 'salary-negotiation.session',
    persona: { initials: 'MH', tone: 1, name: 'Maya', role: 'Hiring manager' },
    meta: { mode: 'Negotiation', difficulty: 4, round: '02 / 05', time: '04:12' },
    messages: [
      {
        type: 'ai',
        label: 'Maya · Hiring manager',
        text: '“Your current offer is already at the top of our band. Why do you feel an adjustment is warranted?”',
      },
      {
        type: 'user',
        label: 'You',
        text: '“I’m excited about the role. Based on scope and market data, I’d like to discuss a package closer to…”',
      },
    ],
    typing: 'Maya is responding',
    scores: [
      { label: 'Clarity', value: 86 },
      { label: 'Confidence', value: 78 },
      { label: 'Evidence', value: 91 },
    ],
    tip: 'Try naming a specific range earlier, then pause. You justified the ask well.',
    recording: '04:12',
  },
  {
    id: 'behavioral',
    tabLabel: 'behavioral-loop',
    sessionTitle: 'behavioral-loop.session',
    persona: { initials: 'NR', tone: 2, name: 'Nina', role: 'Recruiter' },
    meta: { mode: 'Behavioral', difficulty: 3, round: '01 / 04', time: '02:47' },
    messages: [
      {
        type: 'ai',
        label: 'Nina · Recruiter',
        text: '“Tell me about a time you took ownership of a project that wasn’t going well — and what specifically you did.”',
      },
      {
        type: 'user',
        label: 'You',
        text: '“We had a launch slipping three weeks. I scoped the risk myself, called the two engineers blocking us, and rebuilt the timeline by Tuesday…”',
      },
    ],
    typing: 'Nina is responding',
    scores: [
      { label: 'Structure', value: 72 },
      { label: 'Specificity', value: 84 },
      { label: 'Impact', value: 79 },
    ],
    tip: 'Lead with the outcome before the process. The “I did X” detail lands — keep it.',
    recording: '02:47',
  },
  {
    id: 'feedback',
    tabLabel: '1on1-feedback',
    sessionTitle: '1on1-feedback.session',
    persona: { initials: 'SP', tone: 3, name: 'Sara', role: 'Peer' },
    meta: { mode: '1:1 Repair', difficulty: 2, round: '01 / 03', time: '03:21' },
    messages: [
      {
        type: 'ai',
        label: 'Sara · Peer',
        text: '“I just want to know — are we still good? I felt like that review came out of nowhere this morning.”',
      },
      {
        type: 'user',
        label: 'You',
        text: '“I should have given you the heads-up before the meeting. That’s on me. What part landed worst for you?”',
      },
    ],
    typing: 'Sara is responding',
    scores: [
      { label: 'Empathy', value: 91 },
      { label: 'Clarity', value: 74 },
      { label: 'Tone', value: 88 },
    ],
    tip: 'Solid repair opener. Don’t rush to solutions — let her name the worst part first.',
    recording: '03:21',
  },
  {
    id: 'pitch',
    tabLabel: 'exec-pitch',
    sessionTitle: 'exec-pitch.session',
    persona: { initials: 'OE', tone: 4, name: 'Omar', role: 'VP' },
    meta: { mode: 'Exec pitch', difficulty: 5, round: '03 / 03', time: '01:58' },
    messages: [
      {
        type: 'ai',
        label: 'Omar · VP',
        text: '“I don’t need the journey. Tell me what changed, what it cost, and what you’d do differently next quarter.”',
      },
      {
        type: 'user',
        label: 'You',
        text: '“Two things changed. Activation jumped 18% after the onboarding rebuild — that cost six engineer-weeks. Net positive…”',
      },
    ],
    typing: 'Omar is responding',
    scores: [
      { label: 'Brevity', value: 81 },
      { label: 'Outcomes', value: 93 },
      { label: 'Tradeoffs', value: 70 },
    ],
    tip: 'Tight intro. Name the tradeoff explicitly — execs reward visible cost/benefit thinking.',
    recording: '01:58',
  },
];

const activeSessionId = previewSessions[0].id;

const heroMeta = [
  'No credit card',
  'Voice + text',
  'Scored coaching',
];

const marquee = [
  'Behavioral interviews',
  'Salary negotiation',
  'Performance reviews',
  'Layoff conversations',
  'PIP discussions',
  'Promotion case',
  'Pitching to execs',
  'Saying no at work',
  'Skip-level 1:1s',
  'Recruiter screens',
  'System design loop',
  'Difficult feedback',
];

const stats = [
  { eyebrow: 'Scenarios', value: '12+', label: 'High-stakes career moments — new ones every week.' },
  { eyebrow: 'Personas', value: '8', label: 'Adaptive AI characters from cautious to combative.' },
  { eyebrow: 'Feedback signals', value: '6', label: 'Scored on clarity, evidence, confidence, structure, tone, pacing.' },
  { eyebrow: 'Replays', value: '∞', label: 'Practice the same moment until you actually own it.' },
];

const useCases = [
  {
    number: '01',
    tag: 'Interview',
    title: 'Behavioral interviews',
    body: 'Answer with structure, evidence, and calm under follow-up pressure.',
    tone: 'yellow',
    bullets: ['STAR-style answers', 'Follow-up drilldowns', 'Cultural-fit traps'],
    difficulty: 3,
    duration: '20 min',
  },
  {
    number: '02',
    tag: 'Compensation',
    title: 'Salary negotiation',
    body: 'Make a clear ask without sounding defensive, vague, or apologetic.',
    tone: 'accent',
    bullets: ['Counter-offers', 'Equity & sign-on', 'Stay-or-walk lines'],
    difficulty: 4,
    duration: '15 min',
  },
  {
    number: '03',
    tag: '1:1',
    title: 'Difficult feedback',
    body: 'Stay grounded while receiving criticism — or giving it directly.',
    tone: 'pink',
    bullets: ['Receiving a low review', 'Coaching a struggling peer', 'Calling out behavior'],
    difficulty: 3,
    duration: '18 min',
  },
  {
    number: '04',
    tag: 'Leadership',
    title: 'Pitching ideas',
    body: 'Sharpen exec-ready narratives and handle pushback live.',
    tone: 'blue',
    bullets: ['Project kickoffs', 'Scope defenses', 'Skip-level pitches'],
    difficulty: 4,
    duration: '20 min',
  },
  {
    number: '05',
    tag: 'Network',
    title: 'LinkedIn networking',
    body: 'Triage recruiter DMs and earn a second touchpoint with senior strangers.',
    tone: 'lime',
    bullets: ['Cold intros', 'Recruiter screens', 'Coffee-chat prep'],
    difficulty: 2,
    duration: '12 min',
  },
  {
    number: '06',
    tag: 'Conflict',
    title: 'Saying no at work',
    body: 'Push back on scope creep without burning capital with stakeholders.',
    tone: 'yellow',
    bullets: ['Scope refusals', 'Capacity guardrails', 'Reprioritization'],
    difficulty: 3,
    duration: '14 min',
  },
