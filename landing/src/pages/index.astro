      initials: 'CD',
      tone: 3,
      name: 'Chloe',
      role: 'Anxious junior',
    },
    meta: { mode: '1:1 Coaching', difficulty: 3, round: '01 / 03', time: '03:21' },
    messages: [
      {
        type: 'ai',
        label: 'Chloe · Anxious junior',
        text: '“Sorry — I just want to make sure I got it right. Should I send the draft to the whole team first, or run it past you again?”',
      },
      {
        type: 'user',
        label: 'You',
        text: '“Run it past me first this round so we can catch issues early. You don’t need permission — just flag what you’re worried about.”',
      },
