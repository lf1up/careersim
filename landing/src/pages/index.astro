---
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';

const githubUrl = import.meta.env.LANDING_GITHUB_URL ?? 'https://github.com/lf1up/careersim';
const appUrl = import.meta.env.LANDING_APP_URL ?? 'https://careersim.ai/register';
const simulationsUrl = import.meta.env.LANDING_SIMULATIONS_URL ?? 'https://careersim.ai/simulations';

const useCases = [
  {
    number: '01',
    title: 'Behavioral interviews',
    body: 'Answer with structure, evidence, and calm under follow-up pressure.',
    tone: 'yellow',
  },
  {
    number: '02',
    title: 'Salary negotiation',
    body: 'Practice making a clear ask without sounding defensive or vague.',
    tone: 'blue',
  },
  {
    number: '03',
    title: 'Difficult feedback',
    body: 'Stay grounded while receiving criticism or giving direct feedback.',
    tone: 'white',
  },
  {
    number: '04',
    title: 'Pitching ideas',
    body: 'Sharpen executive-ready narratives and handle objections live.',
    tone: 'accent',
  },
];

const steps = [
  {
    title: 'Choose a simulation',
    body: 'Select a career moment and persona difficulty.',
  },
  {
    title: 'Practice live',
    body: 'Respond naturally while the AI probes, redirects, and escalates.',
  },
  {
    title: 'Review feedback',
    body: 'See scores, coaching notes, and suggested follow-up drills.',
  },
];

const faqs = [
  {
    question: 'Who is it for?',
    answer:
      'People preparing for interviews, promotions, negotiations, and difficult workplace conversations.',
  },
  {
    question: 'What makes it different?',
    answer:
      'It creates realistic pressure, not static tips. The feedback is tied to what you actually said.',
  },
  {
    question: 'What should launch collect?',
    answer:
      'Email intent, top scenario interest, and the CTA path into account creation.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="careersim.ai helps people practice career-defining conversations through realistic AI simulations and immediate coaching feedback."
    />
    <meta property="og:title" content="careersim.ai - AI career practice simulations" />
    <meta
      property="og:description"
      content="Practice interviews, negotiations, feedback conversations, and pitches before they happen."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://careersim.ai" />
    <meta name="theme-color" content="#fffdf5" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>careersim.ai - Practice career-defining conversations</title>
  </head>
  <body>
    <header class="site-header">
      <a class="wordmark" href="/" aria-label="careersim.ai home">careersim.ai</a>

      <nav class="nav-links" aria-label="Landing page sections">
        <a href="#use-cases">Use cases</a>
        <a href="#how-it-works">How it works</a>
        <a href="#faq">FAQ</a>
      </nav>

      <div class="header-actions">
        <a class="icon-button" href={githubUrl} target="_blank" rel="noreferrer" aria-label="View careersim.ai on GitHub">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path>
          </svg>
        </a>
        <a class="button button-accent header-cta" href={appUrl}>Start practicing</a>
      </div>
    </header>

    <main>
      <section class="hero section-paper" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="badge">Private beta · Career practice</p>
          <h1 id="hero-title">Practice career-defining conversations before they happen.</h1>
          <p class="hero-subhead">
            careersim.ai turns interviews, salary talks, performance conversations, and high-stakes pitches into realistic AI simulations with immediate feedback.
          </p>
          <div class="hero-actions">
            <a class="button button-dark" href={appUrl}>Start practicing</a>
            <a class="button button-light" href={simulationsUrl}>See simulations</a>
          </div>
          <p class="proof-strip">12+ scenarios / AI personas / feedback after every session</p>
        </div>

        <aside class="product-preview" aria-label="careersim.ai product preview">
          <div class="window-bar">
            <span class="window-dot dot-red"></span>
            <span class="window-dot dot-yellow"></span>
            <span class="window-dot dot-green"></span>
            <span class="session-title">salary-negotiation.session</span>
          </div>

          <div class="preview-body">
            <article class="message-card message-ai">
              <p class="message-label">Maya · Hiring manager</p>
              <p>“Your current offer is already at the top of our band. Why do you feel an adjustment is warranted?”</p>
            </article>

            <article class="message-card message-user">
              <p class="message-label">You</p>
              <p>“I’m excited about the role. Based on scope and market data, I’d like to discuss a package closer to...”</p>
            </article>

            <article class="feedback-card">
              <p class="message-label">Feedback snapshot</p>
              <strong>Clarity 86 · Confidence 78 · Evidence 91</strong>
              <p>Try naming a specific range earlier, then pause. You justified the ask well.</p>
            </article>
          </div>
        </aside>
      </section>

      <section id="use-cases" class="use-cases section-white" aria-labelledby="use-cases-title">
        <div class="section-heading centered">
          <p class="eyebrow">Practice the hard moments</p>
          <h2 id="use-cases-title">A simulator for conversations that actually change careers.</h2>
        </div>

        <div class="card-grid">
          {
            useCases.map((item) => (
              <article class={`retro-card use-case-card tone-${item.tone}`}>
                <p class="case-number">{item.number}</p>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="how-it-works" class="how-it-works section-paper" aria-labelledby="how-title">
        <div class="section-heading">
          <p class="eyebrow">How it works</p>
          <h2 id="how-title">Deliberate practice, not generic advice.</h2>
          <p>
            Pick a scenario, talk with an adaptive AI persona, then get feedback that explains what improved and what to try next.
          </p>
        </div>

        <div class="steps">
          {
            steps.map((step, index) => (
              <article class={`step-card ${index === 1 ? 'step-card-blue' : ''}`}>
                <span class="step-number">{index + 1}</span>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.body}</p>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section id="faq" class="cta-section" aria-labelledby="cta-title">
        <div class="cta-panel">
          <h2 id="cta-title">Launch with a sharper first impression.</h2>
          <p>
            Use the landing page to collect early users, explain the product fast, and route motivated people into registration.
          </p>
          <a class="button button-dark" href={appUrl}>Join the beta</a>
        </div>

        <div class="faq-grid">
          {
            faqs.map((item) => (
              <article class="faq-card">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </article>
            ))
          }
        </div>

        <footer class="site-footer">
          <span class="footer-wordmark">careersim.ai</span>
          <a class="icon-button" href={githubUrl} target="_blank" rel="noreferrer" aria-label="View careersim.ai on GitHub">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path>
            </svg>
          </a>
        </footer>
      </section>
    </main>
    <Analytics />
  </body>
</html>
