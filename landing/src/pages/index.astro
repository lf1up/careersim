      initials: 'MW',
      tone: 4,
      name: 'Marcus',
      role: 'VP of Engineering',
    },
    meta: { mode: 'Exec pitch', difficulty: 4, round: '03 / 03', time: '01:58' },
    messages: [
      {
        type: 'ai',
        label: 'Marcus · VP of Engineering',
        text: '“I’ve got about 15 minutes. What were you hoping to get out of this?”',
      },
      {
        type: 'user',
        label: 'You',
        text: '“I’ll keep it tight. I read your post on platform consolidation — wanted your perspective on one specific tradeoff we’re facing.”',
      },
    ],
    typing: 'Marcus is responding',
