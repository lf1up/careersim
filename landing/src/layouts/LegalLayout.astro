---
import Analytics from '@vercel/analytics/astro';
import '../styles/global.css';

const siteName = import.meta.env.LANDING_SITE_NAME?.trim() || 'careersim.local';
const siteUrl = import.meta.env.LANDING_SITE_URL?.trim() || 'https://careersim.local';
const githubUrl = import.meta.env.LANDING_GITHUB_URL ?? 'https://github.com/lf1up/careersim';
const appUrl = import.meta.env.LANDING_APP_URL ?? 'https://careersim.local/register';
const simulationsUrl = import.meta.env.LANDING_SIMULATIONS_URL ?? 'https://careersim.local/simulations';
const blogUrl = import.meta.env.LANDING_BLOG_URL ?? 'https://careersim.local/blog';
const contactEmail = import.meta.env.LANDING_CONTACT_EMAIL ?? 'hello@careersim.local';

interface Props {
  title: string;
  description: string;
  kicker: string;
  lastUpdated: string;
  pagePath: string;
  pageTitle?: string;
}

const { title, description, kicker, lastUpdated, pagePath, pageTitle: pageTitleProp } = Astro.props;
const pageTitle = pageTitleProp ?? `${title} | ${siteName}`;
const canonicalUrl = `${siteUrl.replace(/\/$/, '')}${pagePath}`;

const footerLinks = {
  product: [
    { label: 'Simulations', href: simulationsUrl },
    { label: 'Blog', href: blogUrl },
    { label: 'How it works', href: `${siteUrl}/#how-it-works` },
    { label: 'Personas', href: `${siteUrl}/#personas` },
    { label: 'FAQ', href: `${siteUrl}/#faq` },
  ],
  resources: [
    { label: 'GitHub', href: githubUrl },
    { label: 'Public roadmap', href: githubUrl },
    { label: 'Contact', href: `mailto:${contactEmail}` },
  ],
  legal: [
    { label: 'Privacy', href: '/privacy' },
    { label: 'Terms', href: '/terms' },
    { label: 'Security', href: '/security' },
  ],
};

const githubIcon = `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#fffdf5" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="wordmark" href={siteUrl} aria-label={`${siteName} home`}>
        {siteName}
        <span class="status-pill">Beta</span>
      </a>

      <nav class="nav-links" aria-label="Site sections">
        <a href={`${siteUrl}/#use-cases`}>Use cases</a>
        <a href={`${siteUrl}/#personas`}>Personas</a>
        <a href={`${siteUrl}/#how-it-works`}>How it works</a>
        <a href={`${siteUrl}/#faq`}>FAQ</a>
        <a href={blogUrl}>Blog</a>
      </nav>

      <div class="header-actions">
        <a class="icon-button" href={githubUrl} target="_blank" rel="noreferrer" aria-label={`View ${siteName} on GitHub`}>
          <Fragment set:html={githubIcon} />
        </a>
        <a class="button button-accent header-cta" href={appUrl}>Start practicing</a>
      </div>
    </header>

    <main>
      <section class="legal-hero section-paper" aria-labelledby="legal-title">
        <div class="legal-hero-inner">
          <p class="legal-eyebrow">{kicker}</p>
          <h1 id="legal-title">{title}</h1>
          <p class="legal-summary">{description}</p>
          <p class="legal-meta">
            <span>Last updated</span>
            <strong>{lastUpdated}</strong>
          </p>
        </div>
      </section>

      <section class="legal-body section-white">
        <article class="legal-content">
          <slot />
          <p class="legal-questions">
            Questions about this page? Email <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
          </p>
        </article>
      </section>

      <section class="cta-section legal-cta">
        <footer class="site-footer">
          <div class="footer-brand">
            <a class="footer-wordmark" href={siteUrl} aria-label={`${siteName} home`}>{siteName}</a>
            <p class="footer-blurb">An AI career simulator for the conversations that actually move the needle — interviews, negotiations, 1:1s.</p>
            <div class="footer-socials">
              <a class="icon-button" href={githubUrl} target="_blank" rel="noreferrer" aria-label={`View ${siteName} on GitHub`}>
                <Fragment set:html={githubIcon} />
              </a>
            </div>
          </div>

          <div class="footer-col">
            <h4>Product</h4>
            <ul>
              {footerLinks.product.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div class="footer-col">
            <h4>Resources</h4>
            <ul>
              {footerLinks.resources.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
          <div class="footer-col">
            <h4>Legal</h4>
            <ul>
              {footerLinks.legal.map((link) => (
                <li><a href={link.href}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        </footer>

        <div class="footer-bottom">
          <span>© {new Date().getFullYear()} {siteName} · All rights reserved</span>
          <span>Built with care · <a href={`mailto:${contactEmail}`}>{contactEmail}</a></span>
        </div>
      </section>
    </main>

    <Analytics />
  </body>
</html>
