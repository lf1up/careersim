NODE_ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

DATABASE_URL=postgres://careersim:careersim_password@localhost:5432/careersim

AGENT_API_URL=http://localhost:8001

JWT_SECRET=change-me-in-prod-this-must-be-a-long-random-string
JWT_EXPIRES_IN=7d

# Inactivity-nudge guardrails (see POST /sessions/:id/nudge)
NUDGE_MIN_IDLE_SECONDS=60
NUDGE_MAX_PER_SILENCE=3
