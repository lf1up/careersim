NODE_ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

DATABASE_URL=postgres://careersim:careersim_password@localhost:5432/careersim

AGENT_API_URL=http://localhost:8001

JWT_SECRET=change-me-in-prod-this-must-be-a-long-random-string
JWT_EXPIRES_IN=7d

# Public origin of the Next.js web app. Embedded in outbound emails
# (magic-link sign-in, password reset) so users land on the right host.
WEB_APP_URL=http://localhost:3000

# --------------------------------------------------------------------
# Outbound email (nodemailer)
#
# Leave SMTP_HOST empty in development to log rendered emails to the
# API's logger instead of sending them — you can copy the 6-digit
# verification code / magic link straight out of `pnpm dev` output.
#
# In production, fill in a real SMTP relay (SendGrid, Postmark, AWS
# SES, Mailgun, etc.) — hostname, port, TLS flag, and credentials.
# --------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CareerSim <no-reply@careersim.local>

# --------------------------------------------------------------------
# ALTCHA (proof-of-work CAPTCHA) — protects /auth/register, /auth/login,
# /auth/login/email-link, /auth/resend-verification, /auth/forgot-password.
#
# ALTCHA_HMAC_KEY is a server-only secret used to sign + verify
# challenges. Rotating invalidates in-flight challenges. Use 32+ chars
# of entropy (e.g. `openssl rand -hex 32`).
#
# ALTCHA_MAX_NUMBER controls the proof-of-work target. Higher values =
# slower browser solve time. 50_000 is a sensible default for
# interactive auth flows; raise under attack, lower for low-power
# clients.
# --------------------------------------------------------------------
ALTCHA_HMAC_KEY=change-me-to-a-long-random-string-for-altcha
ALTCHA_MAX_NUMBER=50000
