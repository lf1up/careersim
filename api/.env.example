NODE_ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

DATABASE_URL=postgres://careersim:careersim_password@localhost:5432/careersim

AGENT_API_URL=http://localhost:8001

JWT_SECRET=change-me-in-prod-this-must-be-a-long-random-string
JWT_EXPIRES_IN=7d

# Public origin of the Next.js web app. Embedded in outbound emails
# (magic-link sign-in, password reset) so users land on the right host.
WEB_APP_URL=http://localhost:3000

# --------------------------------------------------------------------
# Outbound email (nodemailer)
#
# Leave SMTP_HOST empty in development to log rendered emails to the
# API's logger instead of sending them — you can copy the 6-digit
# verification code / magic link straight out of `pnpm dev` output.
#
# In production, fill in a real SMTP relay (SendGrid, Postmark, AWS
# SES, Mailgun, etc.) — hostname, port, TLS flag, and credentials.
# --------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CareerSIM <no-reply@careersim.local>

# --------------------------------------------------------------------
# ALTCHA (proof-of-work CAPTCHA) — protects /auth/register, /auth/login,
# /auth/login/email-link, /auth/forgot-password. (/auth/resend-verification
# is intentionally ungated: its pending record can only be created by the
# captcha-gated /auth/register, and abuse is capped by a 3/hour per-mailbox
# rate limit.)
#
# ALTCHA_HMAC_KEY is a server-only secret used to sign + verify
# challenges. Rotating invalidates in-flight challenges. Use 32+ chars
# of entropy (e.g. `openssl rand -hex 32`).
#
# ALTCHA_MAX_NUMBER controls the proof-of-work target. Higher values =
# slower browser solve time. 50_000 is a sensible default for
# interactive auth flows; raise under attack, lower for low-power
# clients.
# --------------------------------------------------------------------
ALTCHA_HMAC_KEY=change-me-to-a-long-random-string-for-altcha
ALTCHA_MAX_NUMBER=50000

# --------------------------------------------------------------------
# Rate limiting (@fastify/rate-limit)
#
# Sustained-request ceiling layered on top of ALTCHA (per-request cost)
# and argon2id (credential brute-force defence). Policies per route
# live in src/plugins/rate-limit.ts; the 200/min global default here
# is the per-IP safety net for any route without an explicit policy.
#
# RATE_LIMIT_ENABLED=false disables the plugin entirely. Useful during
# incidents where the limit itself is an availability problem, or for
# local load tests.
#
# REDIS_URL points at a Redis instance (e.g. the `redis` service from
# docker-compose.local.yml) so buckets are shared across horizontally
# scaled API pods. Leave empty to fall back to a per-process in-memory
# LRU store — fine for single-instance / dev.
# --------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
REDIS_URL=redis://localhost:6379

# --------------------------------------------------------------------
# Session creation quota (per authenticated user)
#
# Each new chat session spins up an agent thread and burns LLM tokens,
# so we cap new-session creation aggressively by default. Raise these
# for internal/demo environments; keep them tight in production.
#
# SESSIONS_CREATE_WINDOW accepts anything @fastify/rate-limit parses —
# e.g. '30 minutes', '1 hour', '6 hours', or a raw milliseconds number.
# --------------------------------------------------------------------
SESSIONS_CREATE_MAX=2
SESSIONS_CREATE_WINDOW=6 hours
