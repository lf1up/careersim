# Environment Configuration Example for RAG Microservice
# Copy this file to .env and update the values

# Authentication Token (minimum 32 characters required)
# Generate a secure random token for production
AUTH_TOKEN=change-me-min-32-characters-long-token

# Authentication Settings
# Set to 'false' to disable authentication (development only)
AUTH_REQUIRED=true

# ChromaDB specific settings
CHROMA_PERSIST_DIR=./chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# API Configuration
API_HOST=127.0.0.1
API_PORT=8002
API_RELOAD=true
