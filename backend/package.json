{
  "name": "careersim-backend",
  "version": "1.0.0",
  "description": "Backend API for CareerSim - AI-Powered Career Skills Simulator",
  "type": "module",
  "main": "dist/server.js",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc && tsc-alias && node scripts/fix-esm-imports.cjs",
    "build:bundle": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/bundle.js --packages=external",
    "obfuscate": "javascript-obfuscator dist --output dist --config obfuscator.config.json",
    "obfuscate:bundle": "javascript-obfuscator dist/bundle.js --output dist/bundle.js --config obfuscator.config.json",
    "start": "node dist/server.js",
    "start:bundle": "node dist/bundle.js",
    "db:migrate": "tsx ./node_modules/typeorm/cli.js migration:run -d src/config/datasource.ts",
    "db:migrate:revert": "tsx ./node_modules/typeorm/cli.js migration:revert -d src/config/datasource.ts",
    "db:generate": "tsx ./node_modules/typeorm/cli.js migration:generate -d src/config/datasource.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed:force": "tsx ./node_modules/typeorm/cli.js schema:drop -d src/config/datasource.ts && tsx ./node_modules/typeorm/cli.js migration:run -d src/config/datasource.ts && pnpm run db:seed",
    "db:reset": "pnpm run db:migrate:revert && pnpm run db:migrate && pnpm run db:seed",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "lint:unused": "ts-prune",
    "security": "eslint src/**/*.ts --config eslint.security.config.js",
    "security:fix": "eslint src/**/*.ts --config eslint.security.config.js --fix",
    "test": "jest -c jest.config.ts",
    "langgraph:server": "tsx src/services/langgraph/standalone-server.ts",
    "langgraph:dev": "nodemon --watch src/services/langgraph src/services/langgraph/standalone-server.ts",
    "langgraph:test": "tsx src/services/langgraph/scripts/test-standalone.ts",
    "langgraph:test:deepeval": "jest -c jest.config.ts src/services/langgraph/tests/ --detectOpenHandles",
    "test:sim:all": "jest -c jest.config.ts src/services/langgraph/tests/simulations/ --detectOpenHandles",
    "test:sim:behavioral": "jest -c jest.config.ts src/services/langgraph/tests/simulations/behavioral-interview.spec.ts --detectOpenHandles",
    "test:sim:data-analyst": "jest -c jest.config.ts src/services/langgraph/tests/simulations/data-analyst-interview.spec.ts --detectOpenHandles",
    "test:sim:tech-fit": "jest -c jest.config.ts src/services/langgraph/tests/simulations/tech-cultural-fit.spec.ts --detectOpenHandles",
    "test:sim:pitching": "jest -c jest.config.ts src/services/langgraph/tests/simulations/pitching-idea.spec.ts --detectOpenHandles",
    "test:sim:saying-no": "jest -c jest.config.ts src/services/langgraph/tests/simulations/saying-no.spec.ts --detectOpenHandles",
    "test:sim:reengaging": "jest -c jest.config.ts src/services/langgraph/tests/simulations/reengaging-employee.spec.ts --detectOpenHandles",
    "test:sim:delegating": "jest -c jest.config.ts src/services/langgraph/tests/simulations/delegating-task.spec.ts --detectOpenHandles",
    "debug:graph:validate": "NODE_OPTIONS='--max-old-space-size=10240' tsx src/services/langgraph/scripts/validate-structure.ts",
    "debug:graph:compile": "NODE_OPTIONS='--max-old-space-size=10240' tsx src/services/langgraph/scripts/debug-compile.ts",
    "debug:graph:invoke": "NODE_OPTIONS='--max-old-space-size=10240' tsx src/services/langgraph/scripts/test-invoke.ts",
    "debug:graph:stream": "NODE_OPTIONS='--max-old-space-size=10240' tsx src/services/langgraph/scripts/test-stream.ts",
    "debug:graph:proactive": "NODE_OPTIONS='--max-old-space-size=10240' tsx src/services/langgraph/scripts/test-proactive.ts",
    "debug:graph:visualize": "tsx src/services/langgraph/scripts/visualize-graph.ts",
    "debug:graph:all": "bash src/services/langgraph/scripts/run-all-tests.sh"
  },
  "keywords": [
    "career",
    "simulation",
    "ai",
    "skills",
    "training",
    "professional-development"
  ],
  "author": "Pavel Vdovenko <reactivecake@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^1.0.0",
    "@langchain/core": "^1.1.8",
    "@langchain/langgraph": "^1.0.1",
    "@langchain/openai": "^1.0.0",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.0.2",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "langsmith": "^0.3.77",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "openai": "^4.20.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "redis": "^5.7.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "stripe": "^14.7.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.17",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^6.4.14",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^3.0.13",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.6",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "deepeval-ts": "^0.1.11",
    "esbuild": "^0.27.0",
    "eslint": "^9.32.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-security-node": "^1.1.1",
    "globals": "^16.5.0",
    "javascript-obfuscator": "^4.1.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "ts-prune": "^0.10.3",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "tsc-alias": {
    "verbose": false,
    "resolveFullPaths": true,
    "fileExtensions": {
      "inputGlob": "{/**/*,*}.{js,jsx,mjs}",
      "outputCheck": [
        ".js",
        ".jsx",
        ".mjs"
      ]
    }
  }
}
