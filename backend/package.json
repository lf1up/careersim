{
  "name": "careersim-backend",
  "version": "1.0.0",
  "description": "Backend API for CareerSim - AI-Powered Career Skills Simulator",
  "main": "dist/server.js",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "db:migrate": "typeorm migration:run -d src/config/datasource.ts",
    "db:migrate:revert": "typeorm migration:revert -d src/config/datasource.ts",
    "db:generate": "typeorm migration:generate -d src/config/datasource.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/scripts/seed.ts",
    "db:seed:force": "typeorm schema:drop -d src/config/datasource.ts && typeorm migration:run -d src/config/datasource.ts && pnpm run db:seed",
    "db:reset": "pnpm run db:migrate:revert && pnpm run db:migrate && pnpm run db:seed",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "security": "eslint src/**/*.ts --config eslint.security.config.js",
    "security:fix": "eslint src/**/*.ts --config eslint.security.config.js --fix",
    "test": "jest -c jest.config.ts",
    "debug:graph:validate": "NODE_OPTIONS='--max-old-space-size=10240' ts-node -r tsconfig-paths/register src/services/langgraph/scripts/validate-structure.ts",
    "debug:graph:compile": "NODE_OPTIONS='--max-old-space-size=10240' ts-node -r tsconfig-paths/register src/services/langgraph/scripts/debug-compile.ts",
    "debug:graph:invoke": "NODE_OPTIONS='--max-old-space-size=10240' ts-node -r tsconfig-paths/register src/services/langgraph/scripts/test-invoke.ts",
    "debug:graph:stream": "NODE_OPTIONS='--max-old-space-size=10240' ts-node -r tsconfig-paths/register src/services/langgraph/scripts/test-stream.ts",
    "debug:graph:proactive": "NODE_OPTIONS='--max-old-space-size=10240' ts-node -r tsconfig-paths/register src/services/langgraph/scripts/test-proactive.ts",
    "debug:graph:visualize": "ts-node -r tsconfig-paths/register src/services/langgraph/scripts/visualize-graph.ts",
    "debug:graph:all": "bash src/services/langgraph/scripts/run-all-tests.sh"
  },
  "keywords": [
    "career",
    "simulation",
    "ai",
    "skills",
    "training",
    "professional-development"
  ],
  "author": "CareerSim Team",
  "license": "SEE LICENSE IN LICENSE.md",
  "dependencies": {
    "@langchain/community": "^0.3.17",
    "@langchain/core": "^0.3.22",
    "@langchain/langgraph": "^0.2.20",
    "@langchain/openai": "^0.3.14",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.0.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.0",
    "jsonwebtoken": "^9.0.2",
    "langsmith": "^0.2.9",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.7",
    "openai": "^4.20.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "redis": "^5.7.0",
    "reflect-metadata": "^0.1.13",
    "socket.io": "^4.7.4",
    "stripe": "^14.7.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^6.4.14",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^3.0.13",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.6",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^9.32.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-security-node": "^1.1.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.8",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "tsc-alias": {
    "verbose": false,
    "resolveFullPaths": true
  }
}